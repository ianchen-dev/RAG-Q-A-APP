# RAG项目部署配置文件
# 注意：此文件使用shell变量格式，修改后请重新运行部署脚本

# Docker镜像配置
TAG="2025090v1"
REGISTRY="crpi-g0adc8mdcoka4w86.cn-shenzhen.personal.cr.aliyuncs.com"
USERNAME="aliyun7228596829"
IMAGE_NAME="sonetto/rag"

# 部署配置
DEPLOY_DIR="/www/wwwroot/RAG"

# 部署选项
SKIP_LOGIN=false
SKIP_PULL=false
SKIP_DEPLOY=false
FORCE_DEPLOY=false

# 日志配置
LOG_LEVEL="INFO"  # DEBUG, INFO, WARNING, ERROR
LOG_FILE="/var/log/rag-deploy.log"

# 超时配置（秒）
DOCKER_LOGIN_TIMEOUT=30
DOCKER_PULL_TIMEOUT=300
COMPOSE_UP_TIMEOUT=120

# 备份配置
ENABLE_BACKUP=true
BACKUP_DIR="/backup/rag"
BACKUP_RETENTION_DAYS=7

# 通知配置（可选）
ENABLE_NOTIFICATION=false
WEBHOOK_URL=""
SLACK_CHANNEL=""
EMAIL_RECIPIENTS=""
