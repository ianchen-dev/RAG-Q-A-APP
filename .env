# 基础环境配置
# 数据库配置
MONGODB_URL=mongodb://localhost:27017
MONGO_DB_NAME=fastapi
MONGODB_COLLECTION_NAME_CHATHISTORY=chat_histories

# API 配置
ONEAPI_API_KEY=your_oneapi_key_here
ONEAPI_BASE_URL=https://api.openai.com/v1

# Redis 配置
REDIS_URL=redis://localhost:6379

# JWT 配置
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 服务器配置
HOST=127.0.0.1
PORT=8080
