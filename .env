# 基础环境配置
# 数据库配置
MONGODB_URL=mongodb://localhost:27017
MONGO_DB_NAME=fastapi
MONGODB_COLLECTION_NAME_CHATHISTORY=chat_histories

# API 配置
ONEAPI_API_KEY=your_oneapi_key_here
ONEAPI_BASE_URL=https://api.openai.com/v1

# Redis 配置
REDIS_URL=redis://localhost:6379

# JWT 配置
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 服务器配置
HOST=127.0.0.1
PORT=8080


#=============日志============

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 日志目录
LOG_DIR=./log

# 应用名称（用于日志文件命名）
APP_NAME=fastapi_app

# 是否输出到控制台 (true/false)
LOG_CONSOLE=true

# 是否启用文件日志 (true/false)
LOG_FILE=true

# 是否单独记录错误日志 (true/false)
LOG_ERROR_FILE=true

# 是否按日期分割日志 (true/false)
LOG_DATE_ROTATION=true

# 单个日志文件最大大小（字节）
LOG_MAX_FILE_SIZE=10485760

# 轮转文件保留数量
LOG_BACKUP_COUNT=5

# 时间轮转时机 (midnight, H, M, S)
LOG_ROTATE_WHEN=midnight

# 轮转间隔
LOG_ROTATE_INTERVAL=1

# 按日期轮转的文件保留天数
LOG_DATE_BACKUP_COUNT=30

# 是否使用详细的日志格式 (true/false)
LOG_DETAILED_FORMAT=true