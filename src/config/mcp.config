# MCP客户端重试配置文件
# 这些配置可以通过环境变量设置，也可以在.env文件中定义

# MCP重试机制配置
# 最大重试次数（不包括首次尝试）
MCP_RETRY_MAX_RETRIES=3

# 基础延迟时间（秒）
# 第一次重试延迟，后续重试将按指数增长
MCP_RETRY_BASE_DELAY=1.0

# 最大延迟时间（秒）
# 重试延迟的上限，防止延迟时间过长
MCP_RETRY_MAX_DELAY=30.0

# 指数退避底数
# 延迟时间增长倍数：delay = base_delay * (exponential_base ^ attempt)
# 建议值：2.0（延迟序列：1s, 2s, 4s, 8s...）
MCP_RETRY_EXPONENTIAL_BASE=2.0

# 是否启用随机抖动
# 抖动可以避免多个实例同时重试造成的雪崩效应
MCP_RETRY_ENABLE_JITTER=true

# 抖动范围（比例）
# 在计算出的延迟时间基础上，添加 ±jitter_range% 的随机变化
# 例如：jitter_range=0.2 表示延迟时间会在原值的80%-120%之间随机变化
MCP_RETRY_JITTER_RANGE=0.2

# MCP客户端初始化配置
# 是否在应用启动时启用MCP重试机制
MCP_ENABLE_RETRY_ON_STARTUP=true

# MCP工具获取配置
# 是否在获取工具时启用重试机制
MCP_ENABLE_RETRY_ON_TOOL_FETCH=true

# MCP健康检查配置
# 健康检查超时时间（秒）
MCP_HEALTH_CHECK_TIMEOUT=5.0

# MCP客户端超时配置
# 初始化超时时间（秒）
MCP_INIT_TIMEOUT=10.0

# 工具获取超时时间（秒）
MCP_TOOL_FETCH_TIMEOUT=15.0

# 调试配置
# 是否启用MCP详细日志
MCP_ENABLE_DEBUG_LOGGING=false

# 示例配置注释：
# 
# 生产环境建议配置：
# MCP_RETRY_MAX_RETRIES=5
# MCP_RETRY_BASE_DELAY=2.0
# MCP_RETRY_MAX_DELAY=60.0
# 
# 开发环境快速失败配置：
# MCP_RETRY_MAX_RETRIES=1
# MCP_RETRY_BASE_DELAY=0.5
# MCP_RETRY_MAX_DELAY=5.0
# 
# 高可用性环境配置：
# MCP_RETRY_MAX_RETRIES=10
# MCP_RETRY_BASE_DELAY=1.0
# MCP_RETRY_MAX_DELAY=120.0
